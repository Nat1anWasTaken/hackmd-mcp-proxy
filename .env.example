BIND_ADDR=127.0.0.1:3000
PUBLIC_BASE_URL=http://127.0.0.1:3000
DATABASE_URL=sqlite://hackmd-mcp-proxy.db

GITHUB_CLIENT_ID=replace-me
GITHUB_CLIENT_SECRET=replace-me

# Generate 32 random bytes and base64 encode them.
# Example: openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=replace-me
SESSION_HASH_KEY=replace-me
ACCESS_TOKEN_HASH_KEY=replace-me
AUTH_CODE_HASH_KEY=replace-me
GITHUB_STATE_HASH_KEY=replace-me

HACKMD_API_URL=https://api.hackmd.io/v1
APP_ENV=development
LOG_FORMAT=pretty
